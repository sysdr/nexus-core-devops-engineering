package nexuscore:agent@0.1.0;

interface react-agent {
  record step-result {
    thought: string,
    action: option<string>,
    action-input: option<string>,
    observation: option<string>,
    final-answer: option<string>,
    step-index: u32,
  }

  /// Execute a single ReAct step. The host calls this in a loop.
  run-step: func(
    query: string,
    history: list<step-result>,
    llm-endpoint: string,
    search-endpoint: string,
    api-key: string,
  ) -> result<step-result, string>;

  /// Reset the internal bump allocator arena between runs.
  reset-arena: func();
}

world agent-world {
  import wasi:http/outgoing-handler@0.2.8;
  import wasi:io/streams@0.2.8;
  import wasi:clocks/wall-clock@0.2.8;
  export react-agent;
}
